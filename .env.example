# Voicaly — environment configuration
# Copy to `.env` and adjust (./run.sh does this automatically on first run).
# `.env` is gitignored.

# Host port to publish the web UI on.
WEBAPP_PORT=7860

# Translation model. Either:
#   - a HuggingFace repo id (downloaded automatically on first use), or
#   - a directory you place under ./models (mounted at /app/models/<name>).
# The default below is a public Japanese->English model that runs out of the
# box with no token. Swap it for your own DPO adapter or any HF model.
DPO_MODEL_PATH=webbigdata/gemma-2-2b-jpn-it-translate

# HuggingFace token. Only required for *gated* base models (e.g. google/gemma-*).
# Leave blank for the public default above.
HF_TOKEN=
